@model IEnumerable<WebApplication1.Models.Book>

<h2>Books Management</h2>

<a href="/Admin/CreateBook">Add New Book</a>

<table border="1" width="100%">

    <tr>
        <th>ID</th>
        <th>Title</th>
        <th>Author</th>
        <th>Quantity</th>
        <th>Action</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>

            <td>@item.Id</td>
            <td>@item.Title</td>
            <td>@item.Author</td>
            <td>@item.Quantity</td>

            <td>
                <a href="/Admin/EditBook/@item.Id">Edit</a> |
                <a href="/Admin/DeleteBook/@item.Id">Delete</a>
            </td>

        </tr>
    }

</table>
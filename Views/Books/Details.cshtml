@model WebApplication1.Models.Book

@{
    ViewBag.Title = "Book Details";

    int borrowed = Model.Borrows?.Count ?? 0;
    int available = Model.Quantity - borrowed;
}

<style>

    body {
        background: linear-gradient(135deg,#74ebd5,#acb6e5);
        font-family: Segoe UI;
    }


    .page {
        max-width: 1100px;
        margin: auto;
        padding: 40px;
    }

    .book-box {
        background: white;
        padding: 35px;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.15);
    }

    .book-top {
        display: flex;
        gap: 40px;
    }

    .book-image {
        width: 260px;
        height: 340px;
        background: linear-gradient(135deg,#667eea,#764ba2);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        border-radius: 10px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.2);
    }

    .book-info {
        flex: 1;
    }

    .book-title {
        font-size: 34px;
        font-weight: bold;
        margin-bottom: 5px;
    }

    .book-author {
        color: #666;
        margin-bottom: 20px;
        font-size: 18px;
    }

    .stat {
        font-weight: bold;
        margin-top: 10px;
        font-size: 16px;
    }

    .borrow-box {
        margin-top: 35px;
        padding-top: 25px;
        border-top: 1px solid #eee;
    }

    .input {
        padding: 10px;
        margin-top: 10px;
        width: 220px;
        border-radius: 6px;
        border: 1px solid #ccc;
        font-size: 15px;
    }

    .btn {
        padding: 12px 20px;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        font-size: 15px;
        transition: 0.2s;
    }

    .borrow-btn {
        background: #28a745;
        color: white;
    }

        .borrow-btn:hover {
            background: #218838;
            transform: translateY(-2px);
        }

    .back-btn {
        background: #4facfe;
        color: white;
        text-decoration: none;
        padding: 12px 20px;
        border-radius: 6px;
        display: inline-block;
        transition: 0.2s;
    }

        .back-btn:hover {
            background: #2b8be6;
            transform: translateY(-2px);
        }

    /* fix lệch nút */
    .button-group {
        margin-top: 20px;
        display: flex;
        gap: 15px;
        align-items: center;
    }
</style>

<div class="page">

    <div class="book-box">

        <div class="book-top">

            <div class="book-image">
                Book Cover
            </div>

            <div class="book-info">

                <div class="book-title">
                    @Model.Title
                </div>

                <div class="book-author">
                    Author: @Model.Author
                </div>

                <p>
                    <b>Description:</b><br />
                    @Model.Description
                </p>

                <p class="stat">
                    Borrowed: @borrowed
                </p>

                <p class="stat">
                    Available: @available
                </p>

            </div>

        </div>

        <div class="borrow-box">

            @if (available > 0)
            {

                <form method="post"
                      action="@Url.Action("BorrowBook","Books")"
                      onsubmit="return validateDate()">

                    <input type="hidden" name="bookId" value="@Model.Id" />

                    <label><b>Return Date</b></label>

                    <br />

                    <input id="returnDate"
                           class="input"
                           type="date"
                           name="returnDate"
                           required />

                    <div class="button-group">

                        <button class="btn borrow-btn" type="submit">
                            Borrow Book
                        </button>

                        <a class="back-btn"
                           href="@Url.Action("Index","Books")">
                            Back to list
                        </a>

                    </div>

                </form>

            }
            else
            {
                <p style="color:red;font-weight:bold">
                    Book not available
                </p>
            }

        </div>

    </div>

</div>

<script>

    function validateDate() {

        let returnDate =
            document.getElementById("returnDate").value;

        let today =
            new Date().toISOString().split("T")[0];

        if (returnDate <= today) {

            alert("Return date must be greater than today!");

            return false;

        }

        return true;
    }

</script>